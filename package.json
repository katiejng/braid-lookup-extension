{
  "name": "sku-extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "sku start",
    "test": "sku test",
    "build": "SKU_TELEMETRY=false && sku build",
    "serve": "sku serve",
    "lint": "sku lint",
    "format": "sku format",
    "build-zip": "yarn build && yarn zip:chrome && yarn zip:firefox",
    "set-version": ".github/scripts/generate_manifest.sh",
    "zip:chrome": "zip -r packaged/chrome.zip dist",
    "zip:firefox": "yarn zip:source && cd dist; zip -r ../packaged/firefox.zip *",
    "zip:source": "git archive HEAD -o packaged/sourceCode.zip",
    "web-ext": "web-ext"
  },
  "dependencies": {
    "axios": "0.21.0",
    "braid-design-system": "29.32.1",
    "dotenv": "10.0.0",
    "fuse.js": "6.4.6",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "sku": "10.13.4"
  },
  "devDependencies": {
    "@types/react": "17.0.11",
    "@types/react-dom": "17.0.7",
    "chrome-webstore-upload": "0.4.4",
    "husky": "6.0.0",
    "web-ext": "6.1.0"
  }
}
